{
  "schemaVersion": 1,
  "kind": "sdkwork.customerservice.plugin",
  "plugin": {
    "code": "taobao",
    "displayName": "Taobao / 淘宝",
    "version": "0.1.0",
    "runtimeLanguages": ["rust"],
    "status": "planned",
    "capabilities": [
      "session.oauth",
      "transport.websocket",
      "message.chat",
      "order.sync",
      "reply.keyword"
    ]
  },
  "entrypoints": {
    "registryFactory": "sdkwork_customerservice_plugin_taobao::register"
  },
  "database": {
    "overlayRegistry": "docs/schema-registry/overlays/taobao.tables.yaml"
  },
  "internalApi": {
    "controlPrefix": "/internal/v3/api/customer_services/plugins/taobao"
  },
  "security": {
    "credentialKinds": ["oauth", "token"],
    "sensitiveFields": ["access_token", "refresh_token", "app_secret"]
  }
}
