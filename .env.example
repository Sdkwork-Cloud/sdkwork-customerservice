# Gateway / service host (customerservice-server)
# Copy to .env for local development or inject via your secret manager in production.
# Frontend Vite URLs: apps/sdkwork-customerservice-pc/.env.example

CUSTOMER_SERVICE_API_BIND=127.0.0.1:18091
CUSTOMER_SERVICE_DATABASE_ENGINE=postgres
CUSTOMER_SERVICE_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/sdkwork_customerservice
SDKWORK_CUSTOMER_SERVICE_DATABASE_AUTO_MIGRATE=true

# Required in production — generate strong random values; never commit real secrets.
CUSTOMER_SERVICE_CREDENTIAL_MASTER_KEY=dev-customerservice-credential-master-key-change-in-production
SDKWORK_CUSTOMERSERVICE_INGRESS_TOKEN=dev-customerservice-ingress-token

# Development only — do not enable in production.
# CUSTOMER_SERVICE_CORS_ALLOW_ALL=true

# Optional tracing
# RUST_LOG=info,sdkwork=debug
