{
  "name": "sdkwork-customerservice-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --dir apps/sdkwork-customerservice-pc dev",
    "dev:h5": "pnpm --dir apps/sdkwork-customerservice-h5 dev",
    "dev:pc": "pnpm --dir apps/sdkwork-customerservice-pc dev",
    "build": "pnpm --dir apps/sdkwork-customerservice-pc build",
    "start": "cargo run -p sdkwork-customerservice-standalone-gateway --bin customerservice-server",
    "test": "pnpm test:node && cargo test --workspace",
    "test:postgres": "cargo test -p sdkwork-communication-customerservice-repository-sqlx --test postgres_ticket_repository -p sdkwork-customerservice-gateway-assembly --test postgres_http_integration -- --ignored --nocapture",
    "test:postgres:required": "node tools/customerservice_postgres_test_required.mjs",
    "smoke:gateway": "node tools/customerservice_gateway_smoke.mjs",
    "workflow:prepare-ci-dependencies": "node scripts/prepare-ci-dependencies.mjs",
    "gateway:assembly:materialize": "node scripts/gateway/assembly-materialize.mjs",
    "gateway:assembly:validate": "node scripts/gateway/assembly-validate.mjs",
    "test:node": "node --test tests/static/*.test.mjs tests/contract/*.test.mjs",
    "check": "pnpm run check:app-composition && pnpm run check:workspace && pnpm route-manifest:check && pnpm api:check && pnpm sdk:check && pnpm db:validate && pnpm plugin:validate && pnpm topology:validate && pnpm topology:profile:check && pnpm deploy:validate && pnpm typecheck",
    "check:workspace": "node ../sdkwork-specs/tools/sync-workspace.mjs --repo sdkwork-customerservice --root . --check && node ../sdkwork-specs/tools/check-workspace-member-protocol.mjs --root . --repo sdkwork-customerservice && node ../sdkwork-specs/tools/check-workspace-federation-paths.mjs --root . && node ../sdkwork-specs/tools/check-workspace-lock-package-paths.mjs --root .",
    "verify": "pnpm check && node ../sdkwork-specs/tools/check-api-response-envelope.mjs --workspace . && pnpm gateway:assembly:validate && pnpm test:node && pnpm fmt:rust:check && cargo clippy --workspace --tests -- -D warnings && cargo test --workspace && pnpm run check:app-composition",
    "deploy:validate": "node ../sdkwork-specs/tools/check-deploy-standard.mjs",
    "typecheck": "tsc --noEmit",
    "fmt:rust": "cargo fmt",
    "fmt:rust:check": "cargo fmt -- --check",
    "sdk:check": "node tools/customerservice_sdk_generate.mjs --check",
    "sdk:generate": "node tools/customerservice_sdk_generate.mjs",
    "api:materialize": "node tools/customerservice_openapi_normalize.mjs && node tools/customerservice_openapi_align.mjs && node tools/customerservice_openapi_export.mjs",
    "api:check": "node tools/customerservice_openapi_align.mjs --check && node tools/customerservice_openapi_export.mjs --check",
    "route-manifest:export": "node tools/customerservice_route_manifest_export.mjs",
    "route-manifest:check": "node tools/customerservice_route_manifest_export.mjs --check",
    "db:validate": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "db:materialize:contract": "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_customerservice_baseline.sql --module-id customerservice --owner customerservice-platform --prefixes communication_ --engines postgres",
    "db:plan": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan",
    "db:init": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init",
    "db:migrate": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate",
    "db:seed": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
    "db:status": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
    "db:drift": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
    "db:drift:check": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
    "plugin:validate": "node tools/customerservice_plugin_validate.mjs",
    "db:bootstrap": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
    "topology:validate": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root . --spec specs/topology.spec.json",
    "topology:profile:check": "node tools/check-topology-profile-consistency.mjs",
    "scaffold": "node tools/scaffold_customerservice_workspace.mjs",
    "check:app-composition": "node ../sdkwork-specs/tools/verify-repo.mjs --root ."
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
