{
  "name": "sdkwork-customerservice-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "stop": "pnpm exec sdkwork-app stop",
    "dev": "pnpm dev:standalone",
    "dev:browser": "pnpm dev:browser:postgres:standalone",
    "dev:desktop": "pnpm dev:desktop:postgres:standalone",
    "build": "pnpm exec sdkwork-app build",
    "start": "cargo run -p sdkwork-api-customerservice-standalone-gateway --bin customerservice-server",
    "test": "pnpm exec sdkwork-app test",
    "test:postgres": "cargo test -p sdkwork-communication-customerservice-repository-sqlx --test postgres_ticket_repository -p sdkwork-api-customerservice-assembly --test postgres_http_integration -- --ignored --nocapture",
    "test:postgres:required": "node tools/customerservice_postgres_test_required.mjs",
    "smoke:gateway": "node tools/customerservice_gateway_smoke.mjs",
    "workflow:prepare-ci-dependencies": "node scripts/prepare-ci-dependencies.mjs",
    "api:assembly:materialize": "node ../sdkwork-specs/tools/materialize-api-assembly.mjs --root .",
    "api:assembly:validate": "node ../sdkwork-specs/tools/validate-api-assembly.mjs --root .",
    "test:node": "node --test tests/static/*.test.mjs tests/contract/*.test.mjs",
    "check": "pnpm exec sdkwork-app check",
    "check:workspace": "node ../sdkwork-specs/tools/sync-workspace.mjs --repo sdkwork-customerservice --root . --check && node ../sdkwork-specs/tools/check-workspace-member-protocol.mjs --root . --repo sdkwork-customerservice && node ../sdkwork-specs/tools/check-workspace-federation-paths.mjs --root . && node ../sdkwork-specs/tools/check-workspace-lock-package-paths.mjs --root .",
    "verify": "pnpm exec sdkwork-app verify",
    "clean": "pnpm exec sdkwork-app clean",
    "deploy:validate": "node ../sdkwork-specs/tools/check-deploy-standard.mjs",
    "typecheck": "tsc --noEmit",
    "format": "cargo fmt",
    "format:check": "cargo fmt -- --check",
    "sdk:check": "node tools/customerservice_sdk_generate.mjs --check",
    "sdk:generate": "node tools/customerservice_sdk_generate.mjs",
    "api:materialize": "node tools/customerservice_openapi_normalize.mjs && node tools/customerservice_openapi_align.mjs && node tools/customerservice_openapi_export.mjs",
    "api:check": "node tools/customerservice_openapi_align.mjs --check && node tools/customerservice_openapi_export.mjs --check",
    "api:materialize:route-manifest": "node tools/customerservice_route_manifest_export.mjs",
    "api:check:route-manifest": "node tools/customerservice_route_manifest_export.mjs --check",
    "db:validate": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "db:materialize:contract": "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_customerservice_baseline.sql --module-id customerservice --owner customerservice-platform --prefixes communication_ --engines postgres",
    "db:plan": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan",
    "db:init": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init",
    "db:migrate": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate",
    "db:seed": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
    "db:status": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
    "db:drift": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
    "db:drift:check": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
    "check:plugin": "node tools/customerservice_plugin_validate.mjs",
    "db:bootstrap": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
    "topology:validate": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root . --spec specs/topology.spec.json",
    "topology:profile:check": "node tools/check-topology-profile-consistency.mjs",
    "install:workspace": "node tools/scaffold_customerservice_workspace.mjs",
    "check:app-composition": "node ../sdkwork-specs/tools/verify-repo.mjs --root .",
    "topology:plan": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs plan --root . --spec specs/topology.spec.json",
    "_sdkwork:build": "pnpm --dir apps/sdkwork-customerservice-pc build",
    "_sdkwork:test": "pnpm test:node && cargo test --workspace",
    "_sdkwork:check": "pnpm run check:app-composition && pnpm run check:workspace && pnpm api:check:route-manifest && pnpm api:check && pnpm sdk:check && pnpm db:validate && pnpm check:plugin && pnpm topology:validate && pnpm topology:profile:check && pnpm deploy:validate && pnpm typecheck",
    "_sdkwork:verify": "pnpm check && node ../sdkwork-specs/tools/check-api-response-envelope.mjs --workspace . && pnpm api:assembly:validate && pnpm test:node && pnpm format:check && cargo clippy --workspace --tests -- -D warnings && cargo test --workspace && pnpm run check:app-composition",
    "_sdkwork:clean": "cargo clean && node -e \"import('node:fs').then(fs => { for (const target of ['apps/sdkwork-customerservice-pc/dist', 'apps/sdkwork-customerservice-h5/dist']) fs.rmSync(target, { recursive: true, force: true }); })\"",
    "dev:standalone": "pnpm exec sdkwork-app dev --deployment-profile standalone",
    "dev:cloud": "pnpm exec sdkwork-app dev --deployment-profile cloud",
    "deploy:validate:standalone": "pnpm exec sdkwork-app deploy:validate --deployment-profile standalone",
    "deploy:validate:cloud": "pnpm exec sdkwork-app deploy:validate --deployment-profile cloud",
    "dev:browser:postgres:standalone": "pnpm exec sdkwork-app dev --runtime-target browser --deployment-profile standalone",
    "dev:desktop:postgres:standalone": "pnpm exec sdkwork-app dev --runtime-target desktop --deployment-profile standalone"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "@sdkwork/app-topology": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
