# standalone.unified-process.development
SDKWORK_CUSTOMER_SERVICE_DEPLOYMENT_PROFILE=standalone
SDKWORK_CUSTOMER_SERVICE_SERVICE_LAYOUT=unified-process
SDKWORK_CUSTOMER_SERVICE_ENVIRONMENT=development
SDKWORK_CUSTOMER_SERVICE_PROFILE_ID=standalone.unified-process.development

CUSTOMER_SERVICE_API_BIND=127.0.0.1:18091
SDKWORK_CUSTOMER_SERVICE_APPLICATION_PUBLIC_INGRESS_BIND=127.0.0.1:18091
SDKWORK_CUSTOMER_SERVICE_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18091
VITE_SDKWORK_CUSTOMER_SERVICE_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18091
SDKWORK_CUSTOMERSERVICE_INGRESS_TOKEN=dev-customerservice-ingress-token
CUSTOMER_SERVICE_CREDENTIAL_MASTER_KEY=dev-customerservice-credential-master-key-change-in-production
CUSTOMER_SERVICE_CORS_ALLOW_ALL=true

SDKWORK_API_CLOUD_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_CUSTOMER_SERVICE_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
VITE_SDKWORK_CUSTOMER_SERVICE_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900

CUSTOMER_SERVICE_DATABASE_ENGINE=postgres
CUSTOMER_SERVICE_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/sdkwork_customerservice
