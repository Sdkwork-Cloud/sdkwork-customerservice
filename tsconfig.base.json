{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@sdkwork/utils": ["../sdkwork-utils/packages/sdkwork-utils-typescript/src/index.ts"],
      "@sdkwork/iam-app-sdk": ["../sdkwork-iam/sdks/sdkwork-iam-app-sdk/sdkwork-iam-app-sdk-typescript/generated/server-openapi/src/index.ts"],
      "@sdkwork/appbase-pc-react": ["../sdkwork-appbase/packages/pc-react/foundation/sdkwork-appbase-pc-react/src/index.ts"],
      "@sdkwork/sdk-common": ["../sdkwork-sdk-commons/sdkwork-sdk-common-typescript/src/index.ts"],
      "@sdkwork/customerservice-pc-shell": ["apps/sdkwork-customerservice-pc/packages/sdkwork-customerservice-pc-shell/src/index.tsx"],
      "@sdkwork/customerservice-pc-core": ["apps/sdkwork-customerservice-pc/packages/sdkwork-customerservice-pc-core/src/index.ts"],
      "@sdkwork/customerservice-contracts": ["packages/common/customerservice/sdkwork-customerservice-contracts/src/index.ts"],
      "@sdkwork/customerservice-client-core": ["packages/common/customerservice/sdkwork-customerservice-client-core/src/index.ts"],
      "@sdkwork/customerservice-service": ["packages/common/customerservice/sdkwork-customerservice-service/src/index.ts"],
      "@sdkwork/customerservice-h5-core": ["apps/sdkwork-customerservice-h5/packages/sdkwork-customerservice-h5-core/src/index.ts"],
      "@sdkwork/customerservice-h5-shell": ["apps/sdkwork-customerservice-h5/packages/sdkwork-customerservice-h5-shell/src/index.tsx"],
      "@sdkwork/drive-app-sdk": ["../sdkwork-drive/sdks/sdkwork-drive-app-sdk/sdkwork-drive-app-sdk-typescript/src/index.ts"],
      "sdkwork-customerservice-app-sdk-generated-typescript": ["sdks/sdkwork-customerservice-app-sdk/sdkwork-customerservice-app-sdk-typescript/generated/server-openapi/src/index.ts"],
      "sdkwork-customerservice-backend-sdk-generated-typescript": ["sdks/sdkwork-customerservice-backend-sdk/sdkwork-customerservice-backend-sdk-typescript/generated/server-openapi/src/index.ts"]
    },
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"]
  }
}
